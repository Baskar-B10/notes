Filters and Interceptors:
Custom Servlet Filter:
    @Component
    @Order(1)                                // execution order
    public class RequestLoggingFilter extends OncePerRequestFilter {
    
        @Override
        protected void doFilterInternal(HttpServletRequest request,
                                        HttpServletResponse response,
                                        FilterChain chain)
                throws ServletException, IOException {
    
            long start = System.currentTimeMillis();
            String requestId = UUID.randomUUID().toString();
    
            // set on MDC for log tracing
            MDC.put("requestId", requestId);
            response.setHeader("X-Request-Id", requestId);
    
            try {
                chain.doFilter(request, response);  // pass to next filter / servlet
            } finally {
                long duration = System.currentTimeMillis() - start;
                log.info("{} {} → {} in {}ms",
                    request.getMethod(), request.getRequestURI(),
                    response.getStatus(), duration);
                MDC.clear();
            }
        }
    }
Custom HandlerInterceptor
    @Component
    public class AuthTokenInterceptor implements HandlerInterceptor {
    
        @Override
        public boolean preHandle(HttpServletRequest request,
                                 HttpServletResponse response,
                                 Object handler) throws Exception {
            String token = request.getHeader("Authorization");
            if (token == null || !tokenService.isValid(token)) {
                response.setStatus(HttpServletResponse.SC_UNAUTHORIZED);
                return false;                // false = stop processing
            }
            return true;                     // true = continue to controller
        }
    
        @Override
        public void postHandle(HttpServletRequest request,
                               HttpServletResponse response,
                               Object handler,
                               ModelAndView modelAndView) {
            // runs after controller, before view render
            // modify model here if needed
        }
    
        @Override
        public void afterCompletion(HttpServletRequest request,
                                    HttpServletResponse response,
                                    Object handler,
                                    Exception ex) {
            // runs after everything — cleanup, release resources
            if (ex != null) log.error("Request failed", ex);
        }
    }
    
    // Register interceptor
    @Configuration
    public class WebConfig implements WebMvcConfigurer {
    
        @Autowired private AuthTokenInterceptor authInterceptor;
    
        @Override
        public void addInterceptors(InterceptorRegistry registry) {
            registry.addInterceptor(authInterceptor)
                    .addPathPatterns("/api/**")          // apply to these paths
                    .excludePathPatterns("/api/public/**", "/actuator/**");
        }
    }

