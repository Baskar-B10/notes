Advanced — Pagination and Sorting
    // Controller — Spring Data Pageable auto-resolved from query params
    // GET /api/orders?page=0&size=10&sort=amount,desc
    @GetMapping
    public Page<Order> list(Pageable pageable) {
        return orderService.findAll(pageable);
    }
    
    // Custom pageable defaults
    @GetMapping
    public Page<Order> list(
            @PageableDefault(size = 20, sort = "createdAt",
                             direction = Sort.Direction.DESC)
            Pageable pageable) {
        return orderService.findAll(pageable);
    }
    
    // Response wrapper for pagination metadata
    @GetMapping
    public ResponseEntity<PagedResponse<Order>> list(Pageable pageable) {
        Page<Order> page = orderService.findAll(pageable);
        PagedResponse<Order> response = PagedResponse.<Order>builder()
            .content(page.getContent())
            .page(page.getNumber())
            .size(page.getSize())
            .totalElements(page.getTotalElements())
            .totalPages(page.getTotalPages())
            .last(page.isLast())
            .build();
        return ResponseEntity.ok(response);
    }
    
    // Enable Pageable resolver in config
    @Configuration
    public class WebConfig implements WebMvcConfigurer {
        @Override
        public void addArgumentResolvers(
                List<HandlerMethodArgumentResolver> resolvers) {
            resolvers.add(new PageableHandlerMethodArgumentResolver());
        }
    }

