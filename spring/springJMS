      private JmsTemplate jmsTemplate;
      // Send to Queue
      public void sendToQueue(Order order) {
          jmsTemplate.convertAndSend("order-queue",
              new OrderEvent(order.getId(), "ORDER_PLACED"),
              message -> {
                  message.setStringProperty("orderId",
                      order.getId().toString());
                  message.setLongProperty("amount",
                      order.getAmount().longValue());
                  // Session ID for ordering guarantee
                  ((ServiceBusJmsMessage) message)
                      .setSessionId(order.getCustomerId().toString());
                  return message;
              });
      }

      // Send to Topic
      public void sendToTopic(Order order) {
          jmsTemplate.convertAndSend("order-events",
              new OrderEvent(order.getId(), "ORDER_PLACED"));
      }

      // Scheduled message (send to future)
      public void sendScheduled(Order order, Instant deliverAt) {
          jmsTemplate.convertAndSend("order-queue",
              new OrderEvent(order.getId(), "ORDER_PLACED"),
              message -> {
                  message.setLongProperty(
                      ServiceBusMessageProperties.SCHEDULED_ENQUEUE_TIME_UTC,
                      deliverAt.toEpochMilli());
                  return message;
              });
      }
  }


