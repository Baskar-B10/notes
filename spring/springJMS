  @Component
  public class OrderEventConsumer {
      // Basic listener
      @RabbitListener(queues = "order-queue")
      public void handleOrderEvent(OrderEvent event,
                                   Channel channel,
                                   @Header(AmqpHeaders.DELIVERY_TAG) long tag)
              throws IOException {
          try {
              paymentService.processPayment(event);
              channel.basicAck(tag, false);   // ack single message
          } catch (BusinessException e) {
              // Reject and DON'T requeue -> goes to DLQ
              channel.basicNack(tag, false, false);
          } catch (TransientException e) {
              // Reject and requeue -> will be retried
              channel.basicNack(tag, false, true);
          }
      }

      // Fanout consumer (receives broadcast)
      @RabbitListener(queues = "email-queue")
      public void sendEmail(OrderEvent event) {
          emailService.sendOrderConfirmation(event);
      }

      // DLQ consumer
      @RabbitListener(queues = "order-dlq")
      public void handleFailedMessage(OrderEvent event) {
          log.error("Dead letter received: {}", event);
          alertService.sendAlert("Message processing failed", event);
      }
  }

