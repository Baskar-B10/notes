  -------------------------------------------------
  spring:
    cloud:
      stream:
        bindings:
          processPayment-in-0:
            destination: order-events     # topic/queue name
            group: payment-group
          processPayment-out-0:
            destination: payment-events
        kafka:                            # kafka-specific settings
          bindings:
            processPayment-in-0:
              consumer:
                start-offset: earliest


