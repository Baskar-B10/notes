  @Service
  public class OrderEventPublisher {
      @Autowired
      private RabbitTemplate rabbitTemplate;
      public void publishOrderPlaced(Order order) {
          OrderEvent event = new OrderEvent(order.getId(), "ORDER_PLACED");
          rabbitTemplate.convertAndSend(
              "order-exchange",      // exchange name
              "order.placed",        // routing key
              event,                 // message (auto-converted to JSON)
              message -> {           // message post-processor
                  message.getMessageProperties().setMessageId(
                      UUID.randomUUID().toString());
                  message.getMessageProperties().setExpiration("30000");
                  return message;
              }
          );
      }
  }

