  @Component
  public class OrderMessageReceiver {

      // Listen to Queue
      @JmsListener(destination = "order-queue",
                   containerFactory = "jmsListenerContainerFactory")
      public void receiveFromQueue(OrderEvent event, Session session)
              throws JMSException {
          try {
              paymentService.processPayment(event);
              session.commit();             // acknowledge (complete message)
          } catch (Exception e) {
              session.rollback();           // nack -> retry -> DLQ after max
          }
      }

      // Listen to Topic Subscription
      @JmsListener(
          destination = "order-events",
          containerFactory = "topicFactory",
          subscription = "payment-sub"     // subscription name
      )
      public void receiveFromTopic(OrderEvent event) {
          paymentService.processPayment(event);
      }

      // Listen to Dead Letter Queue
      @JmsListener(destination = "order-queue/$deadletterqueue")
      public void handleDeadLetter(Message message) throws JMSException {
          log.error("Dead letter: reason={}, desc={}",
              message.getStringProperty("DeadLetterReason"),
              message.getStringProperty("DeadLetterErrorDescription"));
          alertService.notify(message);
      }
  }


