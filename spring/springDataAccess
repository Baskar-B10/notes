            Optional<Product> findFirstByCategory(Category cat); // first match
            // ── Count / Exists ────────────────────────────────
            long countByCategory(Category cat);
            boolean existsByName(String name);
            // ── Delete ────────────────────────────────────────
            void deleteByCategory(Category cat);
            long deleteByStockLessThan(Integer qty); // returns deleted count
        }

5. @Query methods (manual JPQL / native SQL)
        java// ── JPQL (uses entity class names, not table names) ───
        @Query("SELECT p FROM Product p WHERE p.price < :max AND p.stock > 0")
        List<Product> findAvailableUnder(@Param("max") Double max);
        // ── Positional params (instead of named) ──────────────
        @Query("SELECT p FROM Product p WHERE p.name LIKE %?1%")
        List<Product> searchName(String keyword);
        // ── Native SQL (actual table/column names) ─────────────
        @Query(value = "SELECT * FROM products WHERE stock = 0", nativeQuery = true)
        List<Product> findOutOfStock();
        // ── Modifying query (UPDATE / DELETE) ─────────────────
        @Modifying
        @Transactional
        @Query("UPDATE Product p SET p.price = p.price * :factor WHERE p.category = :cat")
        int applyDiscount(@Param("factor") Double factor, @Param("cat") Category cat);
        // Returns int = number of rows affected
        // ── Projection (return only specific fields) ───────────
        @Query("SELECT p.name, p.price FROM Product p WHERE p.category = :cat")
        List<Object[]> findNameAndPrice(@Param("cat") Category cat);

 What Hibernate Actually Does Behind the Scenes

repo.save(product)
  │
  ▼
Hibernate checks: does this entity have an ID?
  │
  ├── No ID → EntityManager.persist(entity)
  │           → INSERT INTO products (...) VALUES (...)
  │           → DB returns generated id
  │           → entity.id is set automatically
  │
  └── Has ID → EntityManager.merge(entity)
              → SELECT to check if exists
              → UPDATE products SET ... WHERE id = ?

repo.findById(1L)
  │
  ▼
Hibernate checks 1st-level cache (EntityManager / persistence context)
  │
  ├── Found in cache → return immediately (no DB hit!)
  │
  └── Not in cache → SELECT * FROM products WHERE id = 1
                   → map ResultSet → Product object
                   → store in cache
                   → return Optional<Product>


