Step 3 — Entity (@Entity)
The entity maps a Java class to a database table.
javapackage com.example.shop.entity;
import jakarta.persistence.*;
import jakarta.validation.constraints.*;
import lombok.*;
import java.time.LocalDateTime;
@Entity
@Table(name = "products")          // table name in DB
@Data                               // Lombok: getters, setters, toString
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Product {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)   // AUTO_INCREMENT
    private Long id;
    @NotBlank(message = "Name is required")
    @Column(nullable = false, length = 100)
    private String name;
    @Column(columnDefinition = "TEXT")
    private String description;
    @NotNull
    @DecimalMin("0.0")
    @Column(nullable = false, precision = 10, scale = 2)
    private Double price;
    @Column(nullable = false)
    private Integer stock = 0;
    @Enumerated(EnumType.STRING)     // stores "ELECTRONICS" not 0
    private Category category;
    @Column(updatable = false)       // set only on create
    private LocalDateTime createdAt;
    private LocalDateTime updatedAt;
    @PrePersist                      // lifecycle hook — auto-set on insert
    protected void onCreate() {
        createdAt = LocalDateTime.now();
        updatedAt = LocalDateTime.now();
    }
    @PreUpdate                       // lifecycle hook — auto-set on update
    protected void onUpdate() {
        updatedAt = LocalDateTime.now();
    }
    public enum Category {
        ELECTRONICS, CLOTHING, FOOD, SPORTS
    }
}

