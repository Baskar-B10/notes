Step 4 — Repository (JpaRepository)
package com.example.shop.repository;
import com.example.shop.entity.Product;
import com.example.shop.entity.Product.Category;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import java.util.List;
import java.util.Optional;
@Repository
public interface ProductRepository extends JpaRepository<Product, Long> {
    // ── 1. Derived Query Methods (Spring auto-generates SQL) ──────────
    List<Product> findByCategory(Category category);
    List<Product> findByNameContainingIgnoreCase(String keyword);
    List<Product> findByPriceBetween(Double min, Double max);
    List<Product> findByStockGreaterThan(Integer quantity);
    Optional<Product> findByName(String name);
    boolean existsByName(String name);
    long countByCategory(Category category);
    // ── 2. JPQL Query (@Query with entity class names) ────────────────
    @Query("SELECT p FROM Product p WHERE p.price < :maxPrice AND p.stock > 0")
    List<Product> findAvailableUnder(@Param("maxPrice") Double maxPrice);
    @Query("SELECT p FROM Product p WHERE p.category = :cat ORDER BY p.price ASC")
    List<Product> findByCategoryOrderedByPrice(@Param("cat") Category cat);
    // ── 3. Native SQL Query ───────────────────────────────────────────
    @Query(value = "SELECT * FROM products WHERE stock = 0", nativeQuery = true)
    List<Product> findOutOfStock();
    // ── 4. Modifying Query (UPDATE / DELETE) ──────────────────────────
    @Modifying
    @Query("UPDATE Product p SET p.stock = p.stock + :qty WHERE p.id = :id")
    int restockProduct(@Param("id") Long id, @Param("qty") Integer qty);
    // ── 5. Pagination-ready (method returns Page or Slice) ────────────
    // Used with: repo.findByCategory(cat, PageRequest.of(0, 10))
    org.springframework.data.domain.Page<Product>
        findByCategory(Category cat, org.springframework.data.domain.Pageable pageable);
}
