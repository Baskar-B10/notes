  public class RangePartitioner implements Partitioner {
      public Map<String, ExecutionContext> partition(int gridSize) {
          // query: SELECT MIN(id), MAX(id) FROM source_table
          // divide range into gridSize equal slices
          // each slice → one ExecutionContext with minId, maxId
          // Worker Step reads: WHERE id BETWEEN :minId AND :maxId
      }
