  BATCH_STEP_EXEC_CONTEXT  → ExecutionContext for restart
  BATCH_JOB_EXEC_CONTEXT   → Job-level ExecutionContext


  USEFUL MONITORING QUERIES:
  ───────────────────────────
  -- Last 10 job runs with status
  SELECT job_instance_id, start_time, end_time, status, exit_code
  FROM batch_job_execution ORDER BY start_time DESC LIMIT 10;

  -- Step performance for a run
  SELECT step_name, read_count, write_count, skip_count,
         TIMESTAMPDIFF(SECOND, start_time, end_time) AS duration_sec
  FROM batch_step_execution WHERE job_execution_id = ?;

  -- Failed jobs needing restart
  SELECT * FROM batch_job_execution WHERE status = 'FAILED';


