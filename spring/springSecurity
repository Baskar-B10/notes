JWT Utility — Supporting Multiple Secrets (Rotation)
@Component
public class JwtUtil {
    // Current active secret
    @Value("${jwt.secret.current}")
    private String currentSecret;
    // Previous secret (still valid during rotation window)
    @Value("${jwt.secret.previous}")
    private String previousSecret;
    @Value("${jwt.access-token.expiry}")   // 900000 = 15 min
    private long accessTokenExpiry;
    @Value("${jwt.refresh-token.expiry}")  // 604800000 = 7 days
    private long refreshTokenExpiry;
    // ── Generate Access Token ─────────────────────────────────
    public String generateAccessToken(UserDetails userDetails) {
        Map<String, Object> claims = new HashMap<>();
        claims.put("roles", userDetails.getAuthorities()
            .stream()
            .map(GrantedAuthority::getAuthority)
            .collect(Collectors.toList()));
        claims.put("type", "ACCESS");
        claims.put("kid", "v3");           // key ID — which secret version
        return buildToken(claims, userDetails.getUsername(), accessTokenExpiry);
    }
    // ── Generate Refresh Token ────────────────────────────────
    public String generateRefreshToken(UserDetails userDetails) {
        Map<String, Object> claims = new HashMap<>();
        claims.put("type", "REFRESH");
        claims.put("kid", "v3");
        return buildToken(claims, userDetails.getUsername(), refreshTokenExpiry);
    }
    // ── Build Token ───────────────────────────────────────────
    private String buildToken(Map<String, Object> claims,
                               String subject, long expiry) {
        return Jwts.builder()
            .setClaims(claims)
            .setSubject(subject)
            .setIssuedAt(new Date())
            .setExpiration(new Date(System.currentTimeMillis() + expiry))
            .setIssuer("my-app")                     // who issued it
            .setAudience("my-app-clients")            // who it's for
            .signWith(getCurrentSignKey(), SignatureAlgorithm.HS256)
            .compact();
    }
    // ── Validate Token — Try Current Then Previous Secret ────
    public Claims validateAndExtractClaims(String token) {
        // Try current secret first
        try {
            return Jwts.parserBuilder()
                .setSigningKey(getCurrentSignKey())
                .build()
                .parseClaimsJws(token)
                .getBody();
        } catch (SignatureException e) {
            // Current secret failed → try previous secret (rotation window)
            try {
                return Jwts.parserBuilder()
                    .setSigningKey(getPreviousSignKey())
                    .build()
                    .parseClaimsJws(token)
                    .getBody();
            } catch (SignatureException ex) {
                throw new InvalidTokenException("Token signature invalid");
            }
        } catch (ExpiredJwtException e) {
            throw new TokenExpiredException("Token has expired");
        }
    }
    public String extractUsername(String token) {
        return validateAndExtractClaims(token).getSubject();
    }
    public boolean isTokenExpired(String token) {
        return validateAndExtractClaims(token)
            .getExpiration().before(new Date());
    }
    private Key getCurrentSignKey() {
        return Keys.hmacShaKeyFor(Decoders.BASE64.decode(currentSecret));
    }
    private Key getPreviousSignKey() {
        return Keys.hmacShaKeyFor(Decoders.BASE64.decode(previousSecret));
    }
}

Refresh Token Service
@Service
@Transactional
public class RefreshTokenService {
    @Autowired private RefreshTokenRepository refreshTokenRepo;
    @Autowired private UserRepository userRepo;
    @Autowired private JwtUtil jwtUtil;
    @Value("${jwt.refresh-token.expiry}")
    private long refreshTokenExpiry;
    // ── Create & Store Refresh Token ──────────────────────────
    public RefreshToken createRefreshToken(String email) {
        // Revoke existing tokens for this user (single session)
        refreshTokenRepo.revokeAllByUserEmail(email);
        RefreshToken refreshToken = new RefreshToken();
        refreshToken.setUser(userRepo.findByEmail(email).orElseThrow());
        refreshToken.setToken(UUID.randomUUID().toString());  // random, not JWT
        refreshToken.setExpiryDate(Instant.now().plusMillis(refreshTokenExpiry));
        refreshToken.setRevoked(false);
        refreshToken.setUsed(false);
        return refreshTokenRepo.save(refreshToken);
    }
    // ── Rotate: Use Refresh Token → Issue New Pair ────────────
    public TokenResponse rotateTokens(String refreshTokenStr,
                                       HttpServletRequest request) {
        // 1. Find token in DB
        RefreshToken refreshToken = refreshTokenRepo
            .findByToken(refreshTokenStr)
            .orElseThrow(() -> new InvalidTokenException("Refresh token not found"));
        // 2. Check if already used (replay attack detection)
        if (refreshToken.isUsed()) {
            // Possible token theft! Revoke ALL tokens for this user
            refreshTokenRepo.revokeAllByUser(refreshToken.getUser());
            throw new SecurityException("Refresh token already used — possible theft!");
        }
        // 3. Check if revoked
        if (refreshToken.isRevoked()) {
            throw new InvalidTokenException("Refresh token has been revoked");
        }
        // 4. Check expiry
        if (refreshToken.getExpiryDate().isBefore(Instant.now())) {
            throw new TokenExpiredException("Refresh token expired — please login again");
        }
        // 5. Mark current refresh token as USED (one-time use)
        refreshToken.setUsed(true);
        refreshTokenRepo.save(refreshToken);
        // 6. Generate NEW access token + NEW refresh token (rotation)
        User user = refreshToken.getUser();
        UserDetails userDetails = loadUserDetails(user);
        String newAccessToken  = jwtUtil.generateAccessToken(userDetails);
        RefreshToken newRefreshToken = createRefreshToken(user.getEmail());
        return TokenResponse.builder()
            .accessToken(newAccessToken)
            .refreshToken(newRefreshToken.getToken())
            .accessTokenExpiry(900000L)
            .refreshTokenExpiry(refreshTokenExpiry)
            .build();
    }
    // ── Revoke All Tokens (logout all devices) ────────────────
    public void revokeAllUserTokens(String email) {
        refreshTokenRepo.revokeAllByUserEmail(email);
    }
}

Auth Controller — Full Rotation Flow
@RestController
@RequestMapping("/auth")
public class AuthController {
    @Autowired private AuthenticationManager authManager;
    @Autowired private JwtUtil jwtUtil;
    @Autowired private RefreshTokenService refreshTokenService;
    @Autowired private UserDetailsService userDetailsService;
    // ── Login → Issue Token Pair ──────────────────────────────
    @PostMapping("/login")
    public ResponseEntity<TokenResponse> login(
            @Valid @RequestBody LoginRequest request) {
        // Authenticate credentials
        authManager.authenticate(
            new UsernamePasswordAuthenticationToken(
                request.getEmail(), request.getPassword()
            )
        );
        UserDetails userDetails =
            userDetailsService.loadUserByUsername(request.getEmail());
        // Generate token pair
        String accessToken  = jwtUtil.generateAccessToken(userDetails);
        RefreshToken refreshToken =
            refreshTokenService.createRefreshToken(request.getEmail());
        return ResponseEntity.ok(TokenResponse.builder()
            .accessToken(accessToken)
            .refreshToken(refreshToken.getToken())
            .accessTokenExpiry(900000L)
            .refreshTokenExpiry(604800000L)
            .build());
    }
    // ─ Refresh → Rotate Token Pair ───────────────────────────
    @PostMapping("/refresh-token")
    public ResponseEntity<TokenResponse> refreshToken(
            @RequestBody RefreshRequest request,
            HttpServletRequest httpRequest) {
        // Validate + rotate tokens
        TokenResponse newTokens =
            refreshTokenService.rotateTokens(request.getRefreshToken(), httpRequest);
        return ResponseEntity.ok(newTokens);
    }
    // ── Logout → Revoke Tokens ────────────────────────────────
    @PostMapping("/logout")
    public ResponseEntity<String> logout(
            @AuthenticationPrincipal UserDetails userDetails) {
        refreshTokenService.revokeAllUserTokens(userDetails.getUsername());
        return ResponseEntity.ok("Logged out successfully");
    }
    // ── Logout All Devices ────────────────────────────────────
    @PostMapping("/logout-all")
    public ResponseEntity<String> logoutAll(
            @AuthenticationPrincipal UserDetails userDetails) {
        refreshTokenService.revokeAllUserTokens(userDetails.getUsername());
        return ResponseEntity.ok("Logged out from all devices");
    }
}

