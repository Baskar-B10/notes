Multi-Tenant Resource Server
// Different tenants use different Auth Servers
@Bean
public JwtDecoder multiTenantJwtDecoder() {
    return token -> {
        // Extract issuer from token WITHOUT validating (peek at payload)
        String issuer = JWTParser.parse(token)
            .getJWTClaimsSet()
            .getIssuer();
        // Route to correct decoder based on issuer
        JwtDecoder decoder = switch (issuer) {
            case "https://auth.company-a.com" -> decoderForCompanyA();
            case "https://auth.company-b.com" -> decoderForCompanyB();
            case "https://accounts.google.com" -> decoderForGoogle();
            default -> throw new JwtException("Unknown issuer: " + issuer);
        };
        return decoder.decode(token);
    };
}

JWT vs Opaque Tokens in Resource Server
// JWT (self-contained) — validate locally, no network call
http.oauth2ResourceServer(oauth2 -> oauth2
    .jwt(jwt -> jwt.decoder(jwtDecoder()))
);
// ✅ Fast — no network call per request
// ❌ Cannot revoke immediately (must wait for expiry)

// Opaque Token — call Auth Server to validate (introspection)
http.oauth2ResourceServer(oauth2 -> oauth2
    .opaqueToken(opaque -> opaque
        .introspectionUri("https://auth.mycompany.com/introspect")
        .introspectionClientCredentials("client-id", "client-secret")
    )
);
// ✅ Can revoke immediately
// ❌ Network call on EVERY request → latency

