Resource Server Configuration
@Configuration
@EnableWebSecurity
@EnableMethodSecurity
public class ResourceServerConfig {
    @Bean
    public SecurityFilterChain resourceServerChain(HttpSecurity http)
            throws Exception {
        http
            .csrf(csrf -> csrf.disable())
            // ── Declare as OAuth2 Resource Server ────────────
            .oauth2ResourceServer(oauth2 -> oauth2
                .jwt(jwt -> jwt
                    .decoder(jwtDecoder())              // how to validate tokens
                    .jwtAuthenticationConverter(        // how to extract roles
                        jwtAuthenticationConverter()
                    )
                )
                // Custom error when token is missing/invalid
                .authenticationEntryPoint((req, res, ex) -> {
                    res.setStatus(401);
                    res.setContentType("application/json");
                    res.getWriter().write("""
                        {
                          "error": "Unauthorized",
                          "message": "Valid Bearer token required"
                        }
                    """);
                })
            )
            // ── URL Authorization Rules ───────────────────────
            .authorizeHttpRequests(auth -> auth
                .requestMatchers("/actuator/health").permitAll()
                .requestMatchers("/api/admin/**").hasRole("ADMIN")
                .requestMatchers("/api/user/**").hasRole("USER")
                .anyRequest().authenticated()
            )
            // ── Stateless ─────────────────────────────────────
            .sessionManagement(sess -> sess
                .sessionCreationPolicy(SessionCreationPolicy.STATELESS)
            );
        return http.build();
    }
    // ── JWT Decoder — Validates token signature ───────────────
    @Bean
    public JwtDecoder jwtDecoder() {
        // Option 1: Using Auth Server's public JWKS endpoint
        // Auth server publishes public keys here — Spring fetches automatically
        return JwtDecoders.fromIssuerLocation("https://auth.mycompany.com");
        // Spring fetches https://auth.mycompany.com/.well-known/openid-configuration
        // then fetches JWKS (public keys) and validates token signatures locally
    }
    // Option 2: Using symmetric secret (your own JWT)
    @Bean
    public JwtDecoder jwtDecoderSymmetric(
            @Value("${jwt.secret.current}") String secret) {
        SecretKeySpec key = new SecretKeySpec(
            Decoders.BASE64.decode(secret), "HmacSHA256"
        );
        return NimbusJwtDecoder.withSecretKey(key).build();
    }
    // Option 3: Using RSA public key (asymmetric)
    @Bean
    public JwtDecoder jwtDecoderRSA(
            @Value("classpath:public.pem") RSAPublicKey publicKey) {
        return NimbusJwtDecoder.withPublicKey(publicKey).build();
    }
    // ── Role Converter — Extract roles from JWT claims ────────
    @Bean
    public JwtAuthenticationConverter jwtAuthenticationConverter() {
        JwtGrantedAuthoritiesConverter grantedAuthoritiesConverter =
            new JwtGrantedAuthoritiesConverter();
        // Tell Spring where roles are in the JWT
        grantedAuthoritiesConverter.setAuthoritiesClaimName("roles");
        // Default is "scope" or "scp" — override for custom claim
        grantedAuthoritiesConverter.setAuthorityPrefix("ROLE_");
        // Adds ROLE_ prefix so hasRole("ADMIN") works
        JwtAuthenticationConverter converter = new JwtAuthenticationConverter();
        converter.setJwtGrantedAuthoritiesConverter(grantedAuthoritiesConverter);
        return converter;
    }
}

