// application.yml — routing with TokenRelay (forwards the JWT downstream)
spring:
  cloud:
    gateway:
      routes:
        - id: order-service
          uri: lb://order-service
          predicates:
            - Path=/api/orders/**
          filters:
            - TokenRelay=          # forwards Authorization header to downstream
