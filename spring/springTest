@DataJpaTest — Repository Layer Only
@DataJpaTest                             // H2 in-memory DB auto-configured
class OrderRepositoryTest {
    @Autowired
    private OrderRepository orderRepo;

    @Autowired
    private TestEntityManager em;        // helper for test data setup

    @Test
    void findByStatus_shouldReturnMatchingOrders() {
        // ARRANGE — insert test data via TestEntityManager
        Order o1 = em.persistAndFlush(new Order(null, 100.0, "PENDING"));
        Order o2 = em.persistAndFlush(new Order(null, 200.0, "PENDING"));
        Order o3 = em.persistAndFlush(new Order(null, 300.0, "COMPLETED"));

        // ACT
        List<Order> pending = orderRepo.findByStatus("PENDING");

        // ASSERT
        assertThat(pending).hasSize(2);
        assertThat(pending).extracting(Order::getStatus)
                           .containsOnly("PENDING");
    }

    @Test
    void findTopByAmountGreaterThan_shouldReturnCorrectOrder() {
        em.persistAndFlush(new Order(null, 50.0, "PENDING"));
        em.persistAndFlush(new Order(null, 500.0, "PENDING"));

        Optional<Order> result = orderRepo.findTopByAmountGreaterThan(100.0);

        assertThat(result).isPresent();
        assertThat(result.get().getAmount()).isEqualTo(500.0);
    }
}

Test Configuration and Properties
Always use a separate properties file for tests to avoid polluting production config
# src/test/resources/application-test.yml
spring:
  datasource:
    url: jdbc:h2:mem:testdb
    driver-class-name: org.h2.Driver
  jpa:
    hibernate:
      ddl-auto: create-drop
    show-sql: true
  flyway:
    enabled: false          # disable migrations in test — let Hibernate create schema

logging:
  level:
    org.hibernate.SQL: DEBUG
 Apply test profile in tests
@SpringBootTest
@ActiveProfiles("test")
class OrderIntegrationTest { }

// Or override specific properties inline
@SpringBootTest
@TestPropertySource(properties = {
    "spring.datasource.url=jdbc:h2:mem:testdb",
    "feature.payment.enabled=false"
})
class OrderServiceTest { }

Test Data Management
@Sql — Run SQL Scripts in Tests
@DataJpaTest
class OrderRepositoryTest {

    @Test
    @Sql("/test-data/orders.sql")              // runs before test
    @Sql(scripts = "/test-data/cleanup.sql",
         executionPhase = Sql.ExecutionPhase.AFTER_TEST_METHOD)
    void findAll_shouldReturnSeededOrders() {
        List<Order> orders = orderRepo.findAll();
        assertThat(orders).hasSize(5);
    }
}

// src/test/resources/test-data/orders.sql
// INSERT INTO orders(id, amount, status) VALUES (1, 100.0, 'PENDING');
// INSERT INTO orders(id, amount, status) VALUES (2, 200.0, 'COMPLETED');

@Sql vs @Transactional Rollback

  STRATEGY 1: @Transactional on test class
  ──────────────────────────────────────────
  Each test method runs in a transaction
  Transaction rolls back after each test
  DB always clean between tests
  ✓ Simple, automatic
  ✗ Does not test transaction boundary behaviour

  STRATEGY 2: @Sql cleanup scripts
  ──────────────────────────────────
  Run INSERT before test, DELETE after test
  Works even without @Transactional
  ✓ Tests real commit/rollback
  ✗ More boilerplate

  STRATEGY 3: Testcontainers (fresh DB per test class)
  ─────────────────────────────────────────────────────
  Spin up real DB in Docker once per test class
  Best isolation, real DB behaviour
  ✓ Identical to production DB engine
  ✗ Slower startup, requires Docker

Testcontainers — Real Database in Tests

Run a real PostgreSQL / MySQL / MongoDB inside Docker during tests
No more "works on H2 but fails on Postgres" surprises

@SpringBootTest
@Testcontainers
@ActiveProfiles("test")
class OrderRepositoryTestcontainersTest {

    @Container
    static PostgreSQLContainer<?> postgres =
        new PostgreSQLContainer<>("postgres:15")
            .withDatabaseName("testdb")
            .withUsername("test")
            .withPassword("test");

    // Wire container URL into Spring datasource dynamically
    @DynamicPropertySource
    static void configureProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.datasource.url", postgres::getJdbcUrl);
        registry.add("spring.datasource.username", postgres::getUsername);
        registry.add("spring.datasource.password", postgres::getPassword);
    }

    @Autowired
    private OrderRepository orderRepo;

    @Test
    void shouldPersistAndRetrieve_onRealPostgres() {
        Order order = orderRepo.save(new Order(null, 999.0, "PENDING"));

        Optional<Order> found = orderRepo.findById(order.getId());

        assertThat(found).isPresent();
        assertThat(found.get().getAmount()).isEqualTo(999.0);
    }
}

Testing Security
@WebMvcTest(OrderController.class)
@Import(SecurityConfig.class)            // import your security config
class OrderControllerSecurityTest {

    @Autowired private MockMvc mockMvc;
    @MockBean  private OrderService orderService;

    @Test
    void placeOrder_shouldReturn401_whenNotAuthenticated() throws Exception {
        mockMvc.perform(post("/api/orders")
                .contentType(APPLICATION_JSON)
                .content("{\"amount\":100}"))
            .andExpect(status().isUnauthorized());
    }

    @Test
    @WithMockUser(roles = "USER")        // simulate authenticated user
    void placeOrder_shouldReturn201_whenAuthenticated() throws Exception {
        when(orderService.placeOrder(any())).thenReturn(new Order(1L, 100.0));

        mockMvc.perform(post("/api/orders")
                .contentType(APPLICATION_JSON)
                .content("{\"amount\":100}"))
            .andExpect(status().isCreated());
    }

    @Test
    @WithMockUser(roles = "GUEST")       // wrong role
    void deleteOrder_shouldReturn403_whenWrongRole() throws Exception {
        mockMvc.perform(delete("/api/orders/1"))
            .andExpect(status().isForbidden());
    }

    @Test
    @WithUserDetails("admin@app.com")    // loads real UserDetailsService
    void adminEndpoint_shouldReturn200_forAdmin() throws Exception {
        mockMvc.perform(get("/api/admin/orders"))
            .andExpect(status().isOk());
    }
}

Testing with WireMock — Mock External APIs

When your service calls an external REST API, use WireMock to stub it

@SpringBootTest
@AutoConfigureWireMock(port = 0)         // random port WireMock server
@ActiveProfiles("test")
class PaymentServiceTest {

    @Autowired
    private PaymentService paymentService;

    @Test
    void charge_shouldReturnSuccess_whenExternalApiResponds() {
        // STUB the external payment gateway
        stubFor(post(urlEqualTo("/payments/charge"))
            .willReturn(aResponse()
                .withStatus(200)
                .withHeader("Content-Type", "application/json")
                .withBody("{\"status\":\"SUCCESS\",\"transactionId\":\"TX123\"}")));

        PaymentResult result = paymentService.charge(new Order(1L, 500.0));

        assertThat(result.getStatus()).isEqualTo("SUCCESS");
        assertThat(result.getTransactionId()).isEqualTo("TX123");
    }

    @Test
    void charge_shouldThrowException_whenExternalApiReturns500() {
        stubFor(post(urlEqualTo("/payments/charge"))
            .willReturn(aResponse().withStatus(500)));

        assertThatThrownBy(() -> paymentService.charge(new Order(1L, 500.0)))
            .isInstanceOf(PaymentException.class);
    }
}

Testing Caching
@SpringBootTest
class OrderServiceCacheTest {

    @Autowired private OrderService orderService;
    @MockBean  private OrderRepository orderRepo;

    @Test
    void findById_shouldHitCacheOnSecondCall() {
        Order order = new Order(1L, 500.0);
        when(orderRepo.findById(1L)).thenReturn(Optional.of(order));

        orderService.findById(1L);   // first call — hits DB
        orderService.findById(1L);   // second call — hits cache
        orderService.findById(1L);   // third call — hits cache

        // Repository called only ONCE despite 3 service calls
        verify(orderRepo, times(1)).findById(1L);
    }
}

