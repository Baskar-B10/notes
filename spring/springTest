  Layer 1 — Unit Tests (No Spring Context)

Fastest tests, zero Spring startup cost
All dependencies are mocked using Mockito
Test one class in complete isolation
Should form 70% of your test suite

Basic Unit Test
      // Service under test
      @Service
      public class OrderService {
          private final OrderRepository orderRepo;
          private final PaymentService paymentService;
      
          public OrderService(OrderRepository orderRepo,
                              PaymentService paymentService) {
              this.orderRepo = orderRepo;
              this.paymentService = paymentService;
          }
      
          public Order placeOrder(Order order) {
              if (order.getAmount() <= 0) {
                  throw new IllegalArgumentException("Amount must be positive");
              }
              paymentService.charge(order);
              return orderRepo.save(order);
          }
      }

// Unit Test
      @ExtendWith(MockitoExtension.class)          // ← Mockito only, no Spring
      class OrderServiceTest {
          @Mock
          private OrderRepository orderRepo;       // ← mock, no real DB
          @Mock
          private PaymentService paymentService;   // ← mock, no real HTTP call
          @InjectMocks
          private OrderService orderService;       // ← real instance, mocks injected
          @Test
          void placeOrder_shouldSaveOrder_whenAmountIsValid() {
              // ARRANGE
              Order order = new Order(1L, 500.0);
              when(orderRepo.save(order)).thenReturn(order);
              // ACT
              Order result = orderService.placeOrder(order);
              // ASSERT
              assertThat(result).isNotNull();
              assertThat(result.getAmount()).isEqualTo(500.0);
              // VERIFY interactions
              verify(paymentService, times(1)).charge(order);
              verify(orderRepo, times(1)).save(order);
          }
      
          @Test
          void placeOrder_shouldThrowException_whenAmountIsZero() {
              Order order = new Order(1L, 0.0);
              assertThatThrownBy(() -> orderService.placeOrder(order))
                  .isInstanceOf(IllegalArgumentException.class)
                  .hasMessage("Amount must be positive");
              verifyNoInteractions(paymentService);
              verifyNoInteractions(orderRepo);
          }
      }
Mockito Cheat Sheet
    // ── STUBBING ───────────────────────────────────────────────
    when(mock.method(arg)).thenReturn(value);
    when(mock.method(arg)).thenThrow(new RuntimeException());
    when(mock.method(any())).thenReturn(value);        // any argument
    when(mock.method(anyString())).thenReturn(value);
    when(mock.method(eq("exact"))).thenReturn(value);  // exact match
    doNothing().when(mock).voidMethod();               // stub void method
    doThrow(ex).when(mock).voidMethod();               // throw from void

    // ── ARGUMENT CAPTORS ───────────────────────────────────────
    @Captor ArgumentCaptor<Order> orderCaptor;
    
    verify(orderRepo).save(orderCaptor.capture());
    Order captured = orderCaptor.getValue();
    assertThat(captured.getAmount()).isEqualTo(500.0);
    
    // ── VERIFICATION ───────────────────────────────────────────
    verify(mock).method(arg);                  // called exactly once
    verify(mock, times(2)).method(arg);        // called twice
    verify(mock, never()).method(arg);         // never called
    verify(mock, atLeast(1)).method(arg);      // at least once
    verifyNoInteractions(mock);                // zero calls on mock
    verifyNoMoreInteractions(mock);            // no unexpected calls
    
    // ── SPY (partial mock) ─────────────────────────────────────
    @Spy
    private OrderValidator validator;          // real object, some methods stubbed
    doReturn(true).when(validator).validate(any());

Layer 2 — Spring Context Tests:

Spring loads ApplicationContext with your beans
Real dependency injection, real bean lifecycle
Slower than unit tests but catches wiring bugs

    @ExtendWith(SpringExtension.class) — Minimal Context
    // Manual context — you define exactly which beans load
    @ExtendWith(SpringExtension.class)
    @ContextConfiguration(classes = {OrderService.class, OrderConfig.class})
    class OrderServiceSpringTest {
        @Autowired
        private OrderService orderService;  // real Spring-managed bean
        @MockBean
        private OrderRepository orderRepo;  // mock in Spring context
        @Test
        void shouldAutowireCorrectly() {
            assertThat(orderService).isNotNull();
        }
    }

Layer 3 — Spring Boot Integration Tests:
@SpringBootTest loads the FULL application context
Closest to real production behaviour
Supports embedded server, real HTTP calls, real DB

Full Context Test
@SpringBootTest                          // loads full ApplicationContext
@Transactional                           // rolls back after each test
class OrderIntegrationTest {

    @Autowired
    private OrderService orderService;

    @Autowired
    private OrderRepository orderRepo;

    @Test
    void placeOrder_shouldPersistToDatabase() {
        Order order = new Order(null, 750.0);
        Order saved = orderService.placeOrder(order);

        assertThat(saved.getId()).isNotNull();
        assertThat(orderRepo.findById(saved.getId())).isPresent();
    }
}
@SpringBootTest with Embedded Server
@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
class OrderControllerIntegrationTest {

    @Autowired
    private TestRestTemplate restTemplate;     // HTTP client for tests

    @LocalServerPort
    private int port;

    @Test
    void placeOrder_shouldReturn201() {
        Order order = new Order(null, 500.0);

        ResponseEntity<Order> response = restTemplate.postForEntity(
            "/api/orders", order, Order.class);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.CREATED);
        assertThat(response.getBody().getId()).isNotNull();
    }
}

// WebEnvironment options:
// MOCK (default)       → mock servlet, use MockMvc, no real HTTP port
// RANDOM_PORT          → real server on random port, use TestRestTemplate
// DEFINED_PORT         → real server on server.port from properties
// NONE                 → no web layer at all, pure service testing

Layer 4 — Test Slices (Targeted Context Loading)
Test slices load ONLY the layer you care about
Much faster than full @SpringBootTest
Each slice auto-configures only relevant beans

  SLICE ANNOTATION       LOADS                        USE FOR
  ──────────────────────────────────────────────────────────────────────
  @WebMvcTest            Controllers, Filters,        REST API layer
                         HandlerMappings, MockMvc     (no service/repo)

  @DataJpaTest           JPA repos, Hibernate,        Repository layer
                         H2 embedded DB               (no controllers)

  @WebFluxTest           WebFlux controllers           Reactive REST API
                         RouterFunctions

  @DataMongoTest         MongoDB repos                MongoDB repo layer

  @DataRedisTest         Redis repos                  Redis repo layer

  @JsonTest              Jackson ObjectMapper          JSON ser/deser

  @RestClientTest        RestTemplate, MockServer      HTTP client code

  @JdbcTest              JdbcTemplate, H2             Raw JDBC code

  @DataJdbcTest          Spring Data JDBC repos       JDBC repos
  
@WebMvcTest — Controller Layer Only
@WebMvcTest(OrderController.class)       // only this controller loaded
class OrderControllerTest {
    @Autowired
    private MockMvc mockMvc;             // auto-configured

    @MockBean
    private OrderService orderService;   // service mocked — not loaded

    @Autowired
    private ObjectMapper objectMapper;

    @Test
    void placeOrder_shouldReturn201_whenValidRequest() throws Exception {
        Order order = new Order(null, 500.0);
        Order saved  = new Order(1L, 500.0);

        when(orderService.placeOrder(any(Order.class))).thenReturn(saved);

        mockMvc.perform(post("/api/orders")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(order)))
            .andExpect(status().isCreated())
            .andExpect(jsonPath("$.id").value(1L))
            .andExpect(jsonPath("$.amount").value(500.0))
            .andDo(print());             // prints request/response to console
    }

    @Test
    void getOrder_shouldReturn404_whenNotFound() throws Exception {
        when(orderService.findById(99L))
            .thenThrow(new OrderNotFoundException(99L));

        mockMvc.perform(get("/api/orders/99"))
            .andExpect(status().isNotFound())
            .andExpect(jsonPath("$.message").value("Order 99 not found"));
    }
}
