 BETTER PATTERN -- Dedicated config bean
--------------------------------------------------------------------------------
  @Component
  @RefreshScope
  public class OrderConfig {
      @Value("${order.max-items:100}")
      private int maxItems;
      @Value("${order.feature.express-shipping:false}")
      private boolean expressShipping;
      @Value("${order.discount-percentage:0}")
      private double discountPercentage;
      // getters only -- immutable after creation
      public int getMaxItems()           { return maxItems; }
      public boolean isExpressShipping() { return expressShipping; }
      public double getDiscountPercentage() { return discountPercentage; }
  }
  // Inject the config bean -- NOT the values directly
  @Service
  public class OrderService {
      @Autowired
      private OrderConfig orderConfig;  // this is a proxy -- always up to date
      public Order placeOrder(OrderRequest req) {
          if (req.getItems().size() > orderConfig.getMaxItems()) {
              throw new OrderLimitException("Exceeds limit");
          }
      }
  }
 
