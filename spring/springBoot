 Global Exception Handler — Full Example
@RestControllerAdvice
public class GlobalExceptionHandler {
    private static final Logger log = LoggerFactory.getLogger(GlobalExceptionHandler.class);
    // ── Custom App Exceptions ──────────────────────────────────────────
    @ExceptionHandler(UserNotFoundException.class)
    public ResponseEntity<ErrorResponse> handleUserNotFound(
            UserNotFoundException ex, HttpServletRequest request) {

        log.warn("User not found: {}", ex.getMessage());
        ErrorResponse error = new ErrorResponse(
            404, "Not Found", ex.getMessage(), request.getRequestURI()
        );
        return ResponseEntity.status(404).body(error);
    }
    @ExceptionHandler(EmailAlreadyExistsException.class)
    public ResponseEntity<ErrorResponse> handleDuplicateEmail(
            EmailAlreadyExistsException ex, HttpServletRequest request) {

        ErrorResponse error = new ErrorResponse(
            409, "Conflict", ex.getMessage(), request.getRequestURI()
        );
        return ResponseEntity.status(409).body(error);
    }
    // ── Validation Exceptions ──────────────────────────────────────────
    @ExceptionHandler(MethodArgumentNotValidException.class)   // @Valid failures
    public ResponseEntity<ErrorResponse> handleValidation(
            MethodArgumentNotValidException ex, HttpServletRequest request) {
        // Collect all field errors
        Map<String, String> fieldErrors = new HashMap<>();
        ex.getBindingResult().getFieldErrors().forEach(err ->
            fieldErrors.put(err.getField(), err.getDefaultMessage())
        );
        ErrorResponse error = new ErrorResponse(
            400, "Validation Failed", fieldErrors.toString(), request.getRequestURI()
        );
        return ResponseEntity.status(400).body(error);
    }
    @ExceptionHandler(ConstraintViolationException.class)      // @Validated failures
    public ResponseEntity<ErrorResponse> handleConstraintViolation(
            ConstraintViolationException ex, HttpServletRequest request) {

        ErrorResponse error = new ErrorResponse(
            400, "Bad Request", ex.getMessage(), request.getRequestURI()
        );
        return ResponseEntity.status(400).body(error);
    }
    // ── Spring MVC Exceptions ──────────────────────────────────────────
    @ExceptionHandler(HttpRequestMethodNotSupportedException.class)  // wrong HTTP method
    public ResponseEntity<ErrorResponse> handleMethodNotAllowed(
            HttpRequestMethodNotSupportedException ex, HttpServletRequest request) {

        ErrorResponse error = new ErrorResponse(
            405, "Method Not Allowed", ex.getMessage(), request.getRequestURI()
        );
        return ResponseEntity.status(405).body(error);
    }
    @ExceptionHandler(HttpMessageNotReadableException.class)    // malformed JSON body
    public ResponseEntity<ErrorResponse> handleBadJson(
            HttpMessageNotReadableException ex, HttpServletRequest request) {

        ErrorResponse error = new ErrorResponse(
            400, "Bad Request", "Malformed JSON request body", request.getRequestURI()
        );
        return ResponseEntity.status(400).body(error);
    }
    // ── Fallback for Everything Else ───────────────────────────────────
    @ExceptionHandler(Exception.class)
    public ResponseEntity<ErrorResponse> handleAll(
            Exception ex, HttpServletRequest request) {

        log.error("Unexpected error at {}: {}", request.getRequestURI(), ex.getMessage(), ex);
        ErrorResponse error = new ErrorResponse(
            500, "Internal Server Error", "An unexpected error occurred", request.getRequestURI()
        );
        return ResponseEntity.status(500).body(error);
    }
}
