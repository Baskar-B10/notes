Step 3 — Entity (@Entity)
The entity maps a Java class to a database table.
javapackage com.example.shop.entity;
import jakarta.persistence.*;
import jakarta.validation.constraints.*;
import lombok.*;
import java.time.LocalDateTime;
@Entity
@Table(name = "products")          // table name in DB
@Data                               // Lombok: getters, setters, toString
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Product {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)   // AUTO_INCREMENT
    private Long id;
    @NotBlank(message = "Name is required")
    @Column(nullable = false, length = 100)
    private String name;
    @Column(columnDefinition = "TEXT")
    private String description;
    @NotNull
    @DecimalMin("0.0")
    @Column(nullable = false, precision = 10, scale = 2)
    private Double price;
    @Column(nullable = false)
    private Integer stock = 0;
    @Enumerated(EnumType.STRING)     // stores "ELECTRONICS" not 0
    private Category category;
    @Column(updatable = false)       // set only on create
    private LocalDateTime createdAt;
    private LocalDateTime updatedAt;
    @PrePersist                      // lifecycle hook — auto-set on insert
    protected void onCreate() {
        createdAt = LocalDateTime.now();
        updatedAt = LocalDateTime.now();
    }
    @PreUpdate                       // lifecycle hook — auto-set on update
    protected void onUpdate() {
        updatedAt = LocalDateTime.now();
    }
    public enum Category {
        ELECTRONICS, CLOTHING, FOOD, SPORTS
    }
}

Annotation                 Purpose
@Entity                    Marks the class as a JPA-managed entity
@Table                     Customizes table name and constraints
@Id                        Primary key
@GeneratedValue            Auto-increment strategy
@Column                    Customizes column properties
@EnumeratedMaps            enum to STRING or ORDINAL
@PrePersist/ @PreUpdate    Lifecycle callbacks

Step 4 — Repository (JpaRepository)
package com.example.shop.repository;
import com.example.shop.entity.Product;
import com.example.shop.entity.Product.Category;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import java.util.List;
import java.util.Optional;
@Repository
public interface ProductRepository extends JpaRepository<Product, Long> {
    // ── 1. Derived Query Methods (Spring auto-generates SQL) ──────────
    List<Product> findByCategory(Category category);
    List<Product> findByNameContainingIgnoreCase(String keyword);
    List<Product> findByPriceBetween(Double min, Double max);
    List<Product> findByStockGreaterThan(Integer quantity);
    Optional<Product> findByName(String name);
    boolean existsByName(String name);
    long countByCategory(Category category);
    // ── 2. JPQL Query (@Query with entity class names) ────────────────
    @Query("SELECT p FROM Product p WHERE p.price < :maxPrice AND p.stock > 0")
    List<Product> findAvailableUnder(@Param("maxPrice") Double maxPrice);
    @Query("SELECT p FROM Product p WHERE p.category = :cat ORDER BY p.price ASC")
    List<Product> findByCategoryOrderedByPrice(@Param("cat") Category cat);
    // ── 3. Native SQL Query ───────────────────────────────────────────
    @Query(value = "SELECT * FROM products WHERE stock = 0", nativeQuery = true)
    List<Product> findOutOfStock();
    // ── 4. Modifying Query (UPDATE / DELETE) ──────────────────────────
    @Modifying
    @Query("UPDATE Product p SET p.stock = p.stock + :qty WHERE p.id = :id")
    int restockProduct(@Param("id") Long id, @Param("qty") Integer qty);
    // ── 5. Pagination-ready (method returns Page or Slice) ────────────
    // Used with: repo.findByCategory(cat, PageRequest.of(0, 10))
    org.springframework.data.domain.Page<Product>
        findByCategory(Category cat, org.springframework.data.domain.Pageable pageable);
}
Derived query keyword cheat sheet:

Keyword      Example                        SQL equivalent
findBy       findByName                      WHERE name = ?
Containing   findByNameContaining            WHERE name LIKE %?%
Between      findByPriceBetween              WHERE price BETWEEN ? AND ?
GreaterThan  findByStockGreaterThan          WHERE stock > ?
IgnoreCase   findByNameIgnoreCase            WHERE UPPER(name) = UPPER(?)
OrderBy      findByCategoryOrderByPrice      ORDER BY price
And / Or     findByNameAndCategory           WHERE name=? AND category=?

