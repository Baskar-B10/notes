class Trade {
    String clientId;
    String tradeId;
    int quantity;
    String action; // "BUY" or "SELL"

    public Trade(String clientId, String tradeId, int quantity, String action) {
        this.clientId = clientId;
        this.tradeId = tradeId;
        this.quantity = quantity;
        this.action = action;
    }

    public String getClientId() { return clientId; }
    public int getQuantity() { return quantity; }
    public String getAction() { return action; }
}

import java.util.*;
import java.util.stream.Collectors;

public class TradeAggregator {
    public static void main(String[] args) {
        List<Trade> trades = Arrays.asList(
            new Trade("Client_A", "Apple", 100, "BUY"),
            new Trade("Client_A", "Apple", 50, "SELL"),
            new Trade("Client_A", "IBM", 200, "BUY"),
            new Trade("Client_B", "Apple", 300, "BUY"),
            new Trade("Client_B", "Apple", 100, "SELL")
        );

        // Nested Grouping: Client -> TradeID -> Total Quantity
        Map<String, Map<String, Integer>> aggregatedReport = trades.stream()
            .collect(Collectors.groupingBy(
                Trade::getClientId, // Group by Client first
                Collectors.groupingBy(
                    Trade::getTradeId, // Then group by Product/TradeID
                    Collectors.summingInt(t -> 
                        "BUY".equalsIgnoreCase(t.getAction()) ? t.getQuantity() : -t.getQuantity()
                    )
                )
            ));

        // Printing the result in a readable format
        aggregatedReport.forEach((client, productMap) -> {
            System.out.println("Client: " + client);
            productMap.forEach((product, netQty) -> {
                System.out.println("  - " + product + ": " + netQty);
            });
        });
    }
}

[L,L,R,R,T,D] to check if the cursor is at centre or -1
public class CursorPath {
    /**
     * Checks if the moves return the cursor to (0,0)
     * @param moves Array of characters [L, R, T, D]
     * @return 0 if at centre, -1 otherwise
     */
    public static int isAtCentre(char[] moves) {
        // Edge case: if no moves are made, it's at the centre
        if (moves == null || moves.length == 0) return 0;

        int x = 0;
        int y = 0;

        for (char move : moves) {
            if (move == 'L') {
                x--;
            } else if (move == 'R') {
                x++;
            } else if (move == 'T') {
                y++;
            } else if (move == 'D') {
                y--;
            }
        }

        // Logical Check: If net displacement is zero, it's the centre
        return (x == 0 && y == 0) ? 0 : -1;
    }

    public static void main(String[] args) {
        char[] path = {'L', 'L', 'R', 'R', 'T', 'D'};
        System.out.println("Result: " + isAtCentre(path)); 
        // Logic: L(-2) + R(+2) = 0, T(+1) + D(-1) = 0. Output: 0
    }
}
