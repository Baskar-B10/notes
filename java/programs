need output as next highest element in right side

Input Element Elements to the Right Next Highest (Greater)
4     "5, 10, 2, 8"       5
5     "10, 2, 8"         10
10   "2, 8"             -1 (None are > 10)
2     8                   8
8    (None)              -1

import java.util.*;

public class NextGreaterElement {
    public static void findNextGreater(int[] arr) {
        int n = arr.length;
        int[] result = new int[n];
        Stack<Integer> stack = new Stack<>();

        // Iterate from right to left
        for (int i = n - 1; i >= 0; i--) {
            // Remove elements smaller than current from the stack
            while (!stack.isEmpty() && stack.peek() <= arr[i]) {
                stack.pop();
            }

            // If stack is empty, no greater element exists
            result[i] = stack.isEmpty() ? -1 : stack.peek();

            // Push current element for the next iteration
            stack.push(arr[i]);
        }

        System.out.println(Arrays.toString(result));
    }

    public static void main(String[] args) {
        int[] input = {4, 5, 10, 2, 8};
        findNextGreater(input); // Output: [5, 10, -1, 8, -1]
    }
}

